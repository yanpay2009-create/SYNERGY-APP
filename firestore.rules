rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helpers (Phase 3: Primitive Definition)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ["yanpay2009@gmail.com", "synergyflow.my@gmail.com", "synergyflow@gmail.com"] ||
        (isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints (Pillar 2)
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'tier', 'accumulatedSales', 'walletBalance', 'referralCode']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.tier in ['Starter', 'Marketer', 'Builder', 'Executive'] &&
             data.accumulatedSales is number && data.accumulatedSales >= 0 &&
             data.walletBalance is number && data.walletBalance >= 0 &&
             data.teamSize is number && data.teamSize >= 0 &&
             data.accumulatedIncome is number && data.accumulatedIncome >= 0 &&
             data.referralCode is string && data.referralCode.size() <= 20 &&
             data.role in ['admin', 'user'] &&
             (!('kycStatus' in data) || data.kycStatus in ['Unverified', 'Pending', 'Verified', 'Rejected']) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 1000)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('lineId' in data) || (data.lineId is string && data.lineId.size() <= 100)) &&
             (!('pin' in data) || (data.pin is string && data.pin.size() <= 6)) &&
             (!('uplineId' in data) || (data.uplineId is string && data.uplineId.size() <= 128)) &&
             (!('uplinePath' in data) || (data.uplinePath is list && data.uplinePath.size() <= 100)) &&
             (!('favorites' in data) || (data.favorites is list && data.favorites.size() <= 200));
    }

    function isValidPublicProfile(data) {
      return data.keys().hasAll(['name', 'avatar', 'referralCode', 'tier']) &&
             data.name is string && data.name.size() <= 100 &&
             data.avatar is string && data.avatar.size() <= 1000 &&
             data.referralCode is string && data.referralCode.size() <= 20 &&
             data.tier in ['Starter', 'Marketer', 'Builder', 'Executive'] &&
             (!('teamSize' in data) || (data.teamSize is number && data.teamSize >= 0)) &&
             (!('dailyIncome' in data) || (data.dailyIncome is number && data.dailyIncome >= 0)) &&
             (!('accumulatedIncome' in data) || (data.accumulatedIncome is number && data.accumulatedIncome >= 0)) &&
             (!('lastIncomeDate' in data) || (data.lastIncomeDate is string || data.lastIncomeDate == null)) &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('uid' in data) || (data.uid is string && data.uid.size() <= 128)) &&
             (!('uplinePath' in data) || (data.uplinePath is list && data.uplinePath.size() <= 100)) &&
             (!('referrerCode' in data) || (data.referrerCode is string || data.referrerCode == null)) &&
             (!('uplineId' in data) || (data.uplineId is string || data.uplineId == null)) &&
             data.keys().size() <= 20;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image', 'category', 'sold', 'stock']) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 1000 &&
             data.category is string && data.category.size() <= 100 &&
             data.sold is number && data.sold >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'date', 'items', 'total', 'status', 'shippingAddress']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.status in ['Pending', 'To Ship', 'Shipped', 'Delivered', 'Cancelled', 'Return Pending', 'Returned'] &&
             data.total is number && data.total >= 0;
    }

    function isValidFeedItem(data) {
      return data.keys().hasAll(['type', 'category', 'user', 'userId', 'content', 'caption', 'status', 'likes', 'shares', 'isAi']) &&
             data.type in ['image', 'video'] &&
             data.category in ['Trending', 'For You'] &&
             data.status in ['Approved', 'Pending'] &&
             data.likes is number && data.likes >= 0 &&
             data.shares is number && data.shares >= 0 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.caption is string && data.caption.size() <= 2000 &&
             data.content is string && data.content.size() <= 2000;
    }

    function isValidCommission(data) {
      return data.keys().hasAll(['userId', 'date', 'source', 'type', 'amount', 'status']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.type in ['Direct', 'Team', 'Withdrawal', 'Refund'] &&
             data.status in ['Pending', 'Paid', 'Completed', 'Waiting', 'Cancelled'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'date', 'type', 'read']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.type in ['order', 'promo', 'system'] &&
             data.read is bool;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || (isSignedIn() && existing().get('uplinePath', []).contains(request.auth.uid));
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        isAdmin() || (
            incoming().role == existing().role &&
            incoming().email == existing().email &&
            incoming().referralCode == existing().referralCode &&
            // Action: Basic Info (No restricted field modification)
            (
                incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'lineId', 'avatar', 'pin', 'socials', 'addresses', 'bankAccounts', 'savedCards', 'selectedAddressId', 'selectedBankId', 'selectedCardId', 'paymentMethod', 'favorites'])
            ) || (
                // Action: Withdrawal (Allow decreasing walletBalance)
                incoming().diff(existing()).affectedKeys().hasOnly(['walletBalance']) &&
                incoming().walletBalance < existing().walletBalance
            ) || (
                // Action: System Sync (Allow if values haven't changed for protected fields)
                incoming().walletBalance == existing().walletBalance &&
                incoming().accumulatedIncome == existing().accumulatedIncome &&
                incoming().accumulatedSales == existing().accumulatedSales &&
                incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'lineId', 'avatar', 'pin', 'socials', 'addresses', 'bankAccounts', 'savedCards', 'selectedAddressId', 'selectedBankId', 'selectedCardId', 'paymentMethod', 'favorites', 'walletBalance', 'accumulatedIncome', 'accumulatedSales', 'dailyIncome', 'lastIncomeDate', 'referrerCode', 'referrer', 'uplineId', 'uplinePath', 'teamSize'])
            )
        )
      );
      allow delete: if isAdmin();
    }

    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidPublicProfile(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidPublicProfile(incoming()) && (
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'dailyIncome', 'lastIncomeDate', 'accumulatedIncome', 'teamSize', 'totalSales', 'uplinePath', 'referralCode', 'tier', 'uplineId', 'referrerCode', 'role', 'uid', 'displayName', 'photoURL'])
      );
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['sold', 'stock', 'reviews']));
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidOrder(incoming()) && incoming().status == 'Pending';
      allow update: if isAdmin() || (
        isOwner(existing().userId) && 
        isValidOrder(incoming()) && 
        (
          (existing().status == 'Pending' && incoming().status == 'Cancelled') ||
          (existing().status == 'Delivered' && incoming().status == 'Return Pending') ||
          (incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['shippingAddress', 'reviewedProductIds']))
        )
      );
      allow delete: if isAdmin();
    }

    match /feed/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidFeedItem(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && (
          (isOwner(existing().userId) && isValidFeedItem(incoming())) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'likedBy', 'comments', 'shares']))
        )
      );
      allow delete: if isAdmin() || isOwner(existing().userId);
    }

    match /commissions/{txId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (
        isSignedIn() && isValidCommission(incoming()) && (
          (incoming().type in ['Direct', 'Team'] && incoming().sourceUid == request.auth.uid) ||
          (isSignedIn() && incoming().type == 'Withdrawal' && incoming().userId == request.auth.uid && (incoming().status == 'Pending' || incoming().status == 'Waiting')) ||
          (isSignedIn() && incoming().type == 'Refund' && incoming().userId == request.auth.uid)
        )
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || existing().userId == 'global' || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'global' || isAdmin());
      allow create: if isAdmin() || (isSignedIn() && isValidNotification(incoming()));
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && incoming().count == existing().count + 1;
    }

    match /phoneMap/{phone} {
      allow get: if true;
      allow create, update: if isSignedIn();
    }

    match /emailMap/{email} {
      allow get: if true;
      allow create, update: if isSignedIn() && (email == request.auth.token.email || isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/emailMap/$(email))));
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /systemSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /onboardingSlides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /campaignAssets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
